# E-GAZ Antispoof Service — environment variables
# Copy to .env and fill in values before deploying:
#   cp .env.example .env
# Defaults below target the Docker Compose stack (docker-compose.yml,
# antispoof + redis, no mTLS, Laravel talks to 127.0.0.1:8090 on the same
# host). Values called out as "native/systemd only" below need overriding
# if this .env is ever reused for the ./deploy.sh venv+systemd path instead.

# --- Auth (required) ---------------------------------------------------

# Shared secret with Laravel (X-Service-Token header). REQUIRED — do not
# ship this placeholder to production.
# Generate a real value: openssl rand -hex 32
SERVICE_TOKEN=CHANGE_ME

# Deploy environment marker. "prod" makes an EMPTY SERVICE_TOKEN a hard
# startup failure (app/main.py raises RuntimeError before uvicorn binds the
# port) instead of just a log warning — see app/config.py::ENVIRONMENT.
# Always "prod" for this Docker deploy.
ENVIRONMENT=prod

# --- Worker concurrency (required, read this before changing) ----------

# Advisory only inside Docker: entrypoint.sh HARDCODES `uvicorn --workers 1`
# regardless of this value (closes a gap where app/main.py's own
# WEB_CONCURRENCY guard cannot see a --workers CLI flag — see
# entrypoint.sh's comments). Kept here anyway so app/main.py's own guard
# (which DOES read this var directly) agrees with reality and so this file
# stays the single source of truth if the entrypoint is ever touched.
# Do NOT raise this above 1 without first switching SESSION_STORE_BACKEND
# to "redis" below AND editing entrypoint.sh's --workers flag to match.
WEB_CONCURRENCY=1

# --- Liveness challenge SessionStore -----------------------------------

# memory (native/systemd default) = single process only.
# redis (Docker default here) = shared across worker processes/replicas —
# required before WEB_CONCURRENCY/--workers can ever go above 1. The
# docker-compose.yml in this repo always runs its own `redis` container
# (antispoof-redis, internal-network-only, no host port) — REDIS_URL below
# points at it by its compose service name.
SESSION_STORE_BACKEND=redis

# redis://redis:6379/0 only resolves INSIDE the antispoof-net Docker
# network created by docker-compose.yml (service name "redis" ->
# container antispoof-redis). If this .env is ever reused for the
# native/systemd deploy (./deploy.sh, no Docker), override this to a real
# reachable Redis, e.g. redis://localhost:6379/0, or leave
# SESSION_STORE_BACKEND=memory above instead.
REDIS_URL=redis://redis:6379/0

# --- Rate limiting (per-IP sliding window) ------------------------------
RATE_LIMIT_BURST=20
RATE_LIMIT_SUSTAINED=5.0

# --- Liveness detection ---------------------------------------------------

# Liveness detection threshold (0..1). Below = low_quality verdict.
LIVENESS_THRESHOLD=0.5

# Device: auto | cpu | cuda. Target host (egaz-02-compatible: Xeon E5-4620 v2,
# NO GPU) — always "cpu". Do not set "auto" or "cuda" on a CPU-only host;
# "cpu" is explicit and fails loudly instead of silently degrading.
DEVICE=cpu

# Active liveness endpoints (POST /liveness/challenge, POST /liveness/verdict).
# DEFAULT DISABLED — pulls in insightface/onnxruntime + a 260MB ONNX weight
# at startup when true. Existing /verify, /verify_batch, /pad/check are
# unaffected either way. Leave false unless this rollout has been agreed
# with RZA/Umid's team.
LIVENESS_ENDPOINTS_ENABLED=false

# Max batch size for /verify_batch
MAX_BATCH=16

# Comma-separated verdicts that trigger save_frame=true in /pad/check
# responses (Laravel persists the frame when this is set on the verdict).
SAVE_FRAME_VERDICTS=spoof

# --- Layer 0a — deterministic face-to-frame geometry gate ---------------
# Default ON, free/instant (reuses the existing RetinaFace bbox). Rejects
# verdict=spoof/DOCUMENT_PHOTO when face_area/frame_area >= FACE_RATIO_REJECT.
# See app/geometry_check.py for calibration numbers and limitations.
GEOMETRY_CHECK_ENABLED=true
FACE_RATIO_REJECT=0.27

# --- Layer 0b — document/passport-photo pre-filter via minicpm-v (Ollama) --
# DEFAULT DISABLED — calibration found real false positives on plain-
# background bonafide selfies, plus 30-90s latency. See app/document_check.py.
DOCUMENT_CHECK_ENABLED=false
DOCUMENT_CHECK_MODEL=minicpm-v:latest
DOCUMENT_CHECK_OLLAMA_URL=http://127.0.0.1:11434/api/generate
DOCUMENT_REJECT_THRESHOLD=0.70
DOCUMENT_CHECK_TIMEOUT_S=20.0

# --- Anti-replay timestamp window (money-path endpoints only) -----------
# DEFAULT DISABLED — the partner's Laravel client must start sending
# X-Request-Timestamp on every /pad/check, /liveness/challenge,
# /liveness/verdict call FIRST; flipping this on before that turns every
# existing request into a 401. See app/config.py::REPLAY_PROTECTION_ENABLED.
REPLAY_PROTECTION_ENABLED=false
REPLAY_TOLERANCE_S=120

# --- Reverse-proxy topology --------------------------------------------
# DEFAULT FALSE for this deploy: no nginx/mTLS in front — Laravel calls
# 127.0.0.1:8090 directly on the same host, so request.client.host IS the
# real caller. Only flip to true together with deploy/mtls/ if that nginx
# topology is ever adopted later (NOT part of this Docker package).
TRUST_PROXY_HEADERS=false

# --- CORS -----------------------------------------------------------------
# EMPTY by default (production: called server-side by Laravel, not a
# browser, so CORS stays OFF — no CORSMiddleware attached at all). For LOCAL
# manual browser testing via testpage/index.html, set one or more origins
# (comma-separated), e.g.:
#   CORS_ALLOW_ORIGINS=http://127.0.0.1:8090
CORS_ALLOW_ORIGINS=

# --- Audit logging (Docker) ---------------------------------------------
# true (Docker default here) = audit log goes to container stdout, visible
# via `docker compose logs antispoof` / any log driver the host has
# configured — avoids the non-root container user needing write access to a
# host-mounted log file. false/unset = write to ./audit.log inside the
# container's writable layer instead (native/systemd default behavior).
AUDIT_LOG_STDOUT=true
