# E-GAZ Antispoof Service — environment variables
# Copy to .env and fill in values before deploying.

# Shared secret with Laravel (X-Service-Token header).
# Generate: openssl rand -hex 32
# Empty = dev mode (auth disabled, NEVER use in production).
SERVICE_TOKEN=

# Rate limiting (per-IP sliding window)
RATE_LIMIT_BURST=20
RATE_LIMIT_SUSTAINED=5.0

# Liveness detection threshold (0..1). Below = low_quality verdict.
LIVENESS_THRESHOLD=0.5

# Device: auto | cpu | cuda
DEVICE=cpu

# Liveness challenge SessionStore backend: memory | redis.
# memory (default) = single process only, fine for WEB_CONCURRENCY=1 dev/smoke.
# redis = shared across worker processes/replicas — REQUIRED before running
# with more than one worker (see app/liveness_session.py + docs/LIVENESS_CONTRACT_v1.md
# §4 item 7). No silent fallback: if set to redis and Redis is unreachable,
# the service refuses to start.
SESSION_STORE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Max batch size for /verify_batch
MAX_BATCH=16

# Layer 0a — deterministic face-to-frame geometry gate (default ON, free/instant).
# Reuses the existing RetinaFace bbox; rejects verdict=spoof/DOCUMENT_PHOTO when
# face_area/frame_area >= FACE_RATIO_REJECT. See app/geometry_check.py for
# calibration numbers and limitations (n=1 spoof sample; evadable by holding the
# document further from the camera).
GEOMETRY_CHECK_ENABLED=true
FACE_RATIO_REJECT=0.35

# Layer 0b — document/passport-photo pre-filter via minicpm-v (Ollama). DEFAULT
# DISABLED — calibration found ~50% false positives on real bonafide selfies
# with a plain background, plus 30-90s latency. See app/document_check.py.
DOCUMENT_CHECK_ENABLED=false
DOCUMENT_CHECK_MODEL=minicpm-v:latest
DOCUMENT_CHECK_OLLAMA_URL=http://127.0.0.1:11434/api/generate
DOCUMENT_REJECT_THRESHOLD=0.70
DOCUMENT_CHECK_TIMEOUT_S=20.0

# CORS — EMPTY by default (production: service is called server-side by
# Laravel, not a browser, so CORS is not needed and stays OFF = no
# CORSMiddleware attached at all). For LOCAL manual browser testing via
# testpage/index.html, set one or more origins (comma-separated), e.g.:
#   CORS_ALLOW_ORIGINS=http://127.0.0.1:8090
# or, only for quick local dev, allow any origin:
#   CORS_ALLOW_ORIGINS=*
CORS_ALLOW_ORIGINS=
