# --- Secrets / generated certs (NEVER commit) ---
certs/
*.pem
*.key
*.crt
*.csr
*.p12
deploy/mtls/output/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Env / secrets / logs ---
.env
.env.*
*.log

# --- OS / editor cruft ---
.DS_Store
*.swp
.idea/
.vscode/
.pid

# --- Manual backup snapshots (main.py.bak-*) — never intended for git ---
*.bak-*

# --- Local-only manual browser test page (dev tool, not needed in prod) ---
testpage/

# --- Runtime dedup store DB (app/dedup_store.py) — generated at runtime,
# never checked in; DEDUP_ENABLED defaults False so this is normally empty,
# but a local dev run with it flipped on should not pollute git status. ---
models/dedup_store.sqlite3
*.sqlite3
*.sqlite3-journal
